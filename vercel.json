{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "echo 'Flutter SDK is fetched in the build step (scripts/vercel-build.sh)'",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "app/build/web",
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://portionspot-motors.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://portionspot-motors.firebaseapp.com/__/firebase/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
