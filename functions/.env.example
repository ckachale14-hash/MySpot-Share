# Non-secret config for Cloud Functions (committed as an example).
# Copy to functions/.env and adjust per environment. The real .env is gitignored.
#
# OpenAI model IDs by tier — keep IDs here (or in Remote Config), never hardcoded.
# Pick current OpenAI model IDs for each tier (a cheap "mini", a "standard",
# and a "flagship" for long-form). Review periodically as OpenAI ships newer models.
AI_MODEL_FAST=REPLACE_WITH_CHEAP_MINI_MODEL
AI_MODEL_STANDARD=REPLACE_WITH_STANDARD_MODEL
AI_MODEL_PREMIUM=REPLACE_WITH_FLAGSHIP_MODEL
AI_MODERATION_MODEL=REPLACE_WITH_MODERATION_MODEL

# SECRETS DO NOT GO HERE. Set them via Secret Manager, e.g.:
#   firebase functions:secrets:set OPENAI_API_KEY
#   firebase functions:secrets:set STRIPE_SECRET
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
